# Vercel frontend + local backend + hybrid DB profile

# GitHub
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repository-name

# LLM
OPENAI_API_KEY=your_openai_api_key

# Backend security
ARCHITECTURE_API_KEY=replace_with_strong_secret

# DB: hybrid (postgres preferred, sqlite fallback)
ARCHITECTURE_DB_BACKEND=hybrid
ARCHITECTURE_POSTGRES_DSN=postgresql://user:password@db.your-supabase-host.supabase.co:5432/postgres
ARCHITECTURE_DB_PATH=.agent_architecture.db

# Queue: local first (switch to redis when needed)
ARCHITECTURE_QUEUE_BACKEND=local
# ARCHITECTURE_REDIS_URL=redis://127.0.0.1:6379/0

# Backend CORS for local dev frontend and vercel domain
ARCHITECTURE_CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001,https://your-vercel-domain.vercel.app

# Optional worker tuning
WORKER_POLL_INTERVAL_SECONDS=0.5
WORKER_DEQUEUE_TIMEOUT_SECONDS=1

